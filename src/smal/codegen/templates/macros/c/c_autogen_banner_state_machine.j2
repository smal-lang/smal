{% macro c_autogen_banner_state_machine(smal) %}
{% set lines = [
    "This file was automatically generated by SMAL (State Machine Abstraction Language)",
    "Machine: " ~ smal.name,
    "Version: " ~ smal.version,
    "",
    "Do not edit this file directly. Any changes should be made in the",
    "corresponding .smal source file and regenerated via the SMAL toolchain."
] %}
{# Indent inside the box before text #}
{% set indent = 3 %}
{# Longest content line #}
{% set max_len = lines | map('length') | max %}
{# Body width between '/* ' and ' */' (indent + text + padding) #}
{% set body_len = indent + max_len %}
{# Border line #}
{% set border = "/* " ~ ("=" * body_len) ~ " */" %}
{{ border }}
/* {{ " " * body_len }} */
{% for line in lines %}
{% if line == "" %}
/* {{ " " * body_len }} */
{% else %}
/* {{ " " * indent }}{{ line }}{{ " " * (body_len - indent - line|length) }} */
{% endif %}
{% endfor %}
/* {{ " " * body_len }} */
{{ border -}}
{% endmacro %}
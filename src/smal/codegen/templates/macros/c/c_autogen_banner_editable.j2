{% macro c_autogen_banner_editable() %}
{% set lines = [
    "This file was originally autogenerated by SMAL (State Machine Abstraction Language)",
    "",
    "This file is meant to be edited to fit the user's application needs.",
    "Any changes made to this file will NOT be preserved if the file is regenerated by the SMAL toolchain!"
] %}
{# Indent inside the box before text #}
{% set indent = 3 %}
{# Longest content line #}
{% set max_len = lines | map('length') | max %}
{# Body width between '/* ' and ' */' (indent + text + padding) #}
{% set body_len = indent + max_len %}
{# Border line #}
{% set border = "/* " ~ ("=" * body_len) ~ " */" %}
{{ border }}
/* {{ " " * body_len }} */
{% for line in lines %}
{% if line == "" %}
/* {{ " " * body_len }} */
{% else %}
/* {{ " " * indent }}{{ line }}{{ " " * (body_len - indent - line|length) }} */
{% endif %}
{% endfor %}
/* {{ " " * body_len }} */
{{ border -}}
{% endmacro %}
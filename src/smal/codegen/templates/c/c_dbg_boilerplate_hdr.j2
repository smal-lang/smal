/**
 * @brief Create an error entry with the provided error code and detail. The timestamp will be set to the current time in milliseconds when the entry is created.
 *
 * @param error_code The error code associated with the error. Negative values can indicate different error types or categories, while non-negative values can be used for specific error codes within those categories.
 * @param detail Additional detail about the error, which can be used for debugging purposes. The interpretation of this field can depend on the error_code, e.g. it could be an address, a value, a bitmask, etc.
 * @return smal_dbg_entry_t A SMAL debug entry of type error with the specified values and the current timestamp.
 */
static inline smal_dbg_entry_t smal_dbg_create_error(int32_t error_code, uint32_t detail)

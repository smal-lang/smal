/**
 * @brief Log a state transition entry into the specified ring buffer with the provided source state, event, target state, and status. This will create a state transition entry with the current timestamp and push it into the ring buffer.
 *
 * @param ring The ring buffer to log the state transition entry into.
 * @param src_state The source state of the transition.
 * @param evt The event that triggered the transition.
 * @param tgt_state The target state of the transition.
 * @param status The status associated with the transition.
 * @return true if the entry was successfully created and pushed into the ring buffer.
 * @return false if the ring buffer is NULL, has no entries, has zero capacity, or if the push operation failed for any reason.
 */
static inline bool smal_dbg_log_transition(smal_dbg_ring_t *ring, uint16_t src_state, uint16_t evt, uint16_t tgt_state,
        int16_t status)
{
    smal_dbg_entry_t entry = smal_dbg_create_transition(src_state, evt, tgt_state, status);
    return smal_dbg_ring_push(ring, &entry);
}


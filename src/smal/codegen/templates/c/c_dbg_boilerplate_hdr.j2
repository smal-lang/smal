/**
 * @brief Flush entries from the ring buffer in batches, sending them through the smal_dbg_flush_packet function. This function manages the state of the flush cycle using the flush_status structure, and sends packets of entries until all entries that were in the ring at the start of the flush cycle have been sent. If null_terminate is true, an additional empty packet will be sent at the end of the flush cycle to indicate completion.
 *
 * @param null_terminate If true, an additional empty packet will be sent at the end of the flush cycle to indicate completion. If false, no additional packet will be sent after the last batch of entries.
 * @param flush_status Pointer to the flush status structure that manages the state of the flush cycle. This should be initialized before starting the flush cycle and will be updated by this function as it progresses through sending packets.
 * @param ring Pointer to the ring buffer containing the entries to be flushed. The entries that will be flushed are those that were in the ring at the start of the flush cycle, as indicated by the pkt_cnt and oldest_idx fields of the flush_status structure.
 * @param user_ctx A user-defined context pointer that will be passed to the smal_dbg_flush_packet function when sending packets. This can be used to provide additional information or state to the flush_packet function as needed.
 */
static inline void smal_dbg_flush(bool null_terminate, smal_dbg_flush_status_t *flush_status, smal_dbg_ring_t *ring,
                                  void *user_ctx)
{
#if SMAL_DBG_MAX_ENTRIES_PER_TRANSMIT == 0u
    return;
#else /* SMAL_DBG_MAX_ENTRIES_PER_TRANSMIT == 0u */
    if ((flush_status == NULL) || (ring == NULL) || (ring->capacity == 0u) || (ring->entries == NULL))
    {
        return;
    }

    if (!flush_status->active)
    {
        flush_status->num_entries_sent = 0u;
        flush_status->entry_count = ring->entry_count;
        flush_status->oldest_idx = ring->oldest_index;
        flush_status->entry_transmit_complete = false;
        flush_status->active = true;
    }

    if (flush_status->entry_transmit_complete)
    {
        flush_status->entry_transmit_complete = false;
        flush_status->active = false;
        if (null_terminate)
        {
            smal_dbg_flush_packet(0, NULL, user_ctx); // Send an empty packet to indicate completion of the flush cycle
        }
        return;
    }

    // If this is not the last packet, we need to calculate how big this one is and send it, and advance our variables
    uint16_t remaining_entries = flush_status->entry_count - flush_status->num_entries_sent;
    uint16_t num_entries_in_pkt = (uint16_t)MIN(SMAL_DBG_MAX_ENTRIES_PER_TRANSMIT, remaining_entries);
    smal_dbg_entry_t pkt[SMAL_DBG_MAX_ENTRIES_PER_TRANSMIT];
    for (uint16_t i = 0u; i < num_entries_in_pkt; i++)
    {
        // Calculate the index of the next entry to send, accounting for wrap-around
        uint16_t idx = (uint16_t)((flush_status->oldest_idx + flush_status->num_entries_sent + i) % ring->capacity);
        pkt[i] = ring->entries[idx];
    }
    flush_status->num_entries_sent += num_entries_in_pkt;
    // If we sent the last of the entries, the next packet should be empty
    if (flush_status->num_entries_sent >= flush_status->entry_count)
    {
        flush_status->entry_transmit_complete = true;
    }
    smal_dbg_flush_packet(sizeof(smal_dbg_entry_t) * num_entries_in_pkt, pkt, user_ctx);
#endif /* SMAL_DBG_MAX_ENTRIES_PER_TRANSMIT == 0u */
}


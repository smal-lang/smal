/**
 * @brief Initialize the flush status structure to its default values. This should be called before starting a new flush cycle.
 *
 * @param flush_status Pointer to the flush status structure to initialize.
 */
static inline void smal_dbg_flush_status_init(smal_dbg_flush_status_t *flush_status)
{
    if (flush_status != NULL)
    {
        flush_status->num_entries_sent = 0u;
        flush_status->entry_count = 0u;
        flush_status->oldest_idx = 0u;
        flush_status->active = false;
        flush_status->entry_transmit_complete = false;
    }
}

/**
 * @brief Initialize a SMAL debug ring buffer with the provided storage and capacity. This should be called before using the ring buffer to log entries.
 *
 * @param ring The ring buffer structure to initialize.
 * @param storage Pointer to the array of smal_dbg_entry_t that will be used as storage for the ring buffer. The size of this array should be at least equal to the capacity.
 * @param capacity The maximum number of entries the ring buffer can hold. This should be less than or equal to the size of the storage array provided.
 */
static inline void smal_dbg_ring_init(smal_dbg_ring_t *ring, smal_dbg_entry_t *storage, uint16_t capacity)
{
    if (ring == NULL)
    {
        return;
    }
    ring->oldest_index = 0u;
    ring->write_index = 0u;
    ring->entry_count = 0u;
    ring->capacity = capacity;
    ring->overwrite_count = 0u;
    ring->entries = storage;
}

/**
 * @brief Clear all entries from the ring buffer and reset its indices and counters. This does not modify the storage array, but simply resets the state of the ring buffer to be empty.
 *
 * @param ring The ring buffer structure to clear.
 */
static inline void smal_dbg_ring_clear(smal_dbg_ring_t *ring)
{
    if (ring == NULL)
    {
        return;
    }
    ring->oldest_index = 0u;
    ring->write_index = 0u;
    ring->entry_count = 0u;
    ring->overwrite_count = 0u;
}

/**
 * @brief Check if the ring buffer is empty, i.e. it contains no valid entries.
 *
 * @param ring The ring buffer structure to check.
 * @return true if the ring buffer is empty (i.e. entry_count is 0), or if the ring pointer is NULL (considered empty in this case).
 * @return false if the ring buffer contains one or more valid entries.
 */
static inline bool smal_dbg_ring_is_empty(const smal_dbg_ring_t *ring)
{
    if (ring == NULL)
    {
        return true;
    }
    return (ring->entry_count == 0u);
}

/**
 * @brief Check if the ring buffer is full, i.e. it has reached its maximum capacity and the next push will overwrite the oldest entry.
 *
 * @param ring The ring buffer structure to check.
 * @return true if the ring buffer is full.
 * @return false if the ring buffer's entry count is less than its capacity, or if the ring pointer is NULL (considered not full in this case).
 */
static inline bool smal_dbg_ring_is_full(const smal_dbg_ring_t *ring)
{
    if (ring == NULL)
    {
        return false;
    }
    return (ring->entry_count == ring->capacity);
}

/**
 * @brief Get the index of the oldest entry in the ring buffer, which is the next entry to be read or flushed. This is also the index that will be overwritten next if a new entry is pushed when the ring is full.
 *
 * @param ring The ring buffer structure to query.
 * @return uint16_t The index of the oldest entry in the ring buffer. If the ring pointer is NULL, this function returns 0, but the result should not be used in that case.
 */
static inline uint16_t smal_dbg_ring_oldest_index(const smal_dbg_ring_t *ring)
{
    if (ring == NULL)
    {
        return 0u;
    }
    return ring->oldest_index;
}

/**
 * @brief Push a new entry into the ring buffer. If the ring is full, this will overwrite the oldest entry and update the indices and counters accordingly.
 *
 * @param ring The ring buffer structure to push the entry into.
 * @param entry The entry to be pushed into the ring buffer.
 * @return true if the entry was successfully pushed into the ring buffer.
 * @return false if the ring buffer is NULL, has no entries, or has zero capacity.
 */
static inline bool smal_dbg_ring_push(smal_dbg_ring_t *ring, const smal_dbg_entry_t *entry)
{
    if ((ring == NULL) || (ring->entries == NULL) || (ring->capacity == 0u))
    {
        return false;
    }

    ring->entries[ring->write_index] = *entry;
    ring->write_index = (uint16_t)((ring->write_index + 1u) % ring->capacity);

    if (ring->entry_count < ring->capacity)
    {
        ++ring->entry_count;
    }
    else
    {
        ring->oldest_index = ring->write_index;
        ++ring->overwrite_count;
    }

    return true;
}

/**
 * @brief Get a pointer to the entry at the specified offset from the oldest entry in the ring buffer. The offset should be less than the current entry count of the ring buffer.
 *
 * @param ring The ring buffer structure to query.
 * @param offset The offset from the oldest entry to retrieve, where 0 corresponds to the oldest entry, 1 corresponds to the second oldest entry, etc. The offset should be less than the current entry count of the ring buffer.
 * @return const smal_dbg_entry_t* A pointer to the entry at the specified offset from the oldest entry in the ring buffer. If the offset is out of bounds, or if the ring buffer is NULL, has no entries, or has zero capacity, this function returns NULL.
 */
static inline const smal_dbg_entry_t *smal_dbg_ring_get(const smal_dbg_ring_t *ring, uint16_t offset)
{
    uint16_t oldest_index;
    uint16_t index;

    if ((ring == NULL) || (offset >= ring->entry_count) || (ring->entries == NULL) || (ring->capacity == 0u))
    {
        return NULL;
    }

    oldest_index = smal_dbg_ring_oldest_index(ring);
    index = (uint16_t)((oldest_index + offset) % ring->capacity);
    return &ring->entries[index];
}

/**
 * @brief Get a pointer to the oldest contiguous block of entries in the ring buffer, starting from the oldest entry. This can be used to efficiently flush entries in batches. The number of entries returned will be the minimum of the number of entries currently in the ring buffer and the number of entries from the oldest entry to the end of the storage array (i.e. before wrapping around).
 *
 * @param ring The ring buffer structure to query.
 * @param entries Output parameter that will be set to point to the oldest contiguous block of entries in the ring buffer. If the ring buffer is empty, or if the ring pointer is NULL, or if the entries pointer is NULL, this will be set to NULL.
 * @return uint16_t The number of entries in the contiguous block pointed to by the entries output parameter. This will be 0 if the ring buffer is empty, or if the ring pointer is NULL, or if the entries pointer is NULL.
 */
static inline uint16_t smal_dbg_ring_peek_linear(const smal_dbg_ring_t *ring, const smal_dbg_entry_t **entries)
{
    uint16_t oldest_index;
    uint16_t tail_count;

    if ((entries == NULL) || smal_dbg_ring_is_empty(ring) || (ring->entries == NULL) || (ring->capacity == 0u))
    {
        if (entries != NULL)
        {
            *entries = NULL;
        }
        return 0u;
    }

    oldest_index = smal_dbg_ring_oldest_index(ring);
    *entries = &ring->entries[oldest_index];
    tail_count = (uint16_t)(ring->capacity - oldest_index);

    if (tail_count > ring->entry_count)
    {
        tail_count = ring->entry_count;
    }

    return tail_count;
}

/**
 * @brief Drop the specified number of oldest entries from the ring buffer, effectively advancing the read head. This should be called after flushing a batch of entries to indicate that those entries have been processed and can be overwritten. If the count is greater than the current entry count of the ring buffer, this will drop all entries and reset the ring buffer to be empty.
 *
 * @param ring The ring buffer structure to modify.
 * @param count The number of oldest entries to drop from the ring buffer. This should be less than or equal to the current entry count of the ring buffer. If this value is greater than the current entry count, all entries will be dropped and the ring buffer will be reset to empty.
 * @return uint16_t The actual number of entries dropped from the ring buffer, which will be the minimum of the count parameter and the current entry count of the ring buffer.
 */
static inline uint16_t smal_dbg_ring_drop_oldest(smal_dbg_ring_t *ring, uint16_t count)
{
    if (ring == NULL)
    {
        return 0u;
    }

    if (count > ring->entry_count)
    {
        count = ring->entry_count;
    }

    if ((count != 0u) && (ring->capacity != 0u))
    {
        ring->oldest_index = (uint16_t)((ring->oldest_index + count) % ring->capacity);
    }

    ring->entry_count = (uint16_t)(ring->entry_count - count);
    return count;
}

/**
 * @brief Create a state transition entry with the provided source state, event, target state, and status. The timestamp will be set to the current time in milliseconds when the entry is created.
 *
 * @param src_state The source state of the transition.
 * @param evt The event that triggered the transition.
 * @param tgt_state The target state of the transition.
 * @param status The status associated with the transition.
 * @return smal_dbg_entry_t A SMAL debug entry of type state transition with the specified values and the current timestamp.
 */
static inline smal_dbg_entry_t smal_dbg_create_transition(uint16_t src_state, uint16_t evt, uint16_t tgt_state,
        int16_t status)
{
    smal_dbg_entry_t entry;

    entry.entry_type = SMAL_DBG_ENTRY_TYPE_STATE_TRANSITION;
    entry.timestamp_ms = smal_dbg_get_timestamp_ms();
    entry.payload.transition.src_state = src_state;
    entry.payload.transition.tgt_state = tgt_state;
    entry.payload.transition.evt = evt;
    entry.payload.transition.status = status;

    return entry;
}

/**
 * @brief Create a message entry with the provided entry type, identifier, data length, and value. The timestamp will be set to the current time in milliseconds when the entry is created.
 *
 * @param entry_type The type of the message entry, which should be one of the event/command types defined in smal_dbg_entry_type_t, e.g. SMAL_DBG_ENTRY_TYPE_EVENT_RX, SMAL_DBG_ENTRY_TYPE_CMD_TX, etc.
 * @param identifier The identifier of the event or command, which can be used to specify which event or command this message entry corresponds to.
 * @param data_len The length of the data associated with the event or command, in bytes. This can be used to indicate the size of the payload or parameters, if any.
 * @param value A value associated with the event or command. The interpretation of this field can depend on the context, e.g. it could be a parameter value, a status code, etc.
 * @return smal_dbg_entry_t A SMAL debug entry of type event or command with the specified values and the current timestamp.
 */
static inline smal_dbg_entry_t smal_dbg_create_msg(uint32_t entry_type, uint16_t identifier, uint16_t data_len,
        uint32_t value)
{
    smal_dbg_entry_t entry;

    entry.entry_type = entry_type;
    entry.timestamp_ms = smal_dbg_get_timestamp_ms();
    entry.payload.message.identifier = identifier;
    entry.payload.message.data_len = data_len;
    entry.payload.message.value = value;

    return entry;
}

/**
 * @brief Create a data read entry with the provided address and data length. The timestamp will be set to the current time in milliseconds when the entry is created.
 *
 * @param address The address that was read from. The interpretation of this field can depend on the context, e.g. it could be a memory address, a register address, etc.
 * @param data_len The length of the data that was read, in bytes. This can be used to indicate the size of the operation, e.g. 1 for byte, 2 for half-word, 4 for word, etc.
 * @return smal_dbg_entry_t A SMAL debug entry of type data read with the specified values and the current timestamp.
 */
static inline smal_dbg_entry_t smal_dbg_create_data_read(uint32_t address, uint32_t data_len)
{
    smal_dbg_entry_t entry;

    entry.entry_type = SMAL_DBG_ENTRY_TYPE_DATA_READ;
    entry.timestamp_ms = smal_dbg_get_timestamp_ms();
    entry.payload.data.address = address;
    entry.payload.data.data_len = data_len;

    return entry;
}

